{
  "name": "om-customer-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "node": ">=24.18.0 <25",
    "pnpm": "11.10.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run",
    "validate:deps": "node ./scripts/check-prohibited-deps.mjs",
    "validate": "pnpm lint && pnpm typecheck && pnpm validate:deps && pnpm test && pnpm build",
    "preview": "vite preview",
    "deploy:static": "bash ./scripts/deploy-static.sh"
  },
  "dependencies": {
    "@mantine/core": "^7.17.8",
    "@mantine/hooks": "^7.17.8",
    "@om/contracts": "npm:@omrecords82/contracts@0.1.0",
    "@om/tokens": "npm:@omrecords82/tokens@0.1.0",
    "@om/ui": "npm:@omrecords82/ui@0.1.0",
    "lucide-react": "0.487.0",
    "react": "19.2.0",
    "react-aria-components": "^1.19.0",
    "react-dom": "19.2.0",
    "react-router": "7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2",
    "vitest": "^4.0.8"
  }
}
