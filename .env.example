VITE_PORTAL_BASE_PATH=/portal2
# mock (default) | live — live hits OM /api/auth/*
VITE_PORTAL_AUTH_MODE=mock
# When true, shell routes require a signed-in session
VITE_PORTAL_REQUIRE_AUTH=false
# Cemetery flags — all default false; enable per pilot after geometry validation
VITE_CEMETERY_ENABLED=false
VITE_CEMETERY_MAP_ENABLED=false
VITE_CEMETERY_MAINTENANCE_ENABLED=false
VITE_CEMETERY_REPORTS_ENABLED=false
