VITE_PORTAL_BASE_PATH=/portal2
# mock (default) | live — live hits OM /api/auth/*
# Pilot tenant (sole allowlist): om_church_46 — apply live+requireAuth only for that tenant's deploy; do NOT commit live globally
VITE_PORTAL_AUTH_MODE=mock
# When true, shell routes require a signed-in session
VITE_PORTAL_REQUIRE_AUTH=false
# Cemetery flags — all default false; enable per pilot after geometry validation
VITE_CEMETERY_ENABLED=false
VITE_CEMETERY_MAP_ENABLED=false
VITE_CEMETERY_MAINTENANCE_ENABLED=false
VITE_CEMETERY_REPORTS_ENABLED=false
# Records editor dual-run — one type at a time during pilot; all default false locally
# Production /portal2 pilot deploy sets VITE_PORTAL_RECORDS_EDITOR_BAPTISM=true (marriage/funeral stay false)
VITE_PORTAL_RECORDS_EDITOR_BAPTISM=false
VITE_PORTAL_RECORDS_EDITOR_MARRIAGE=false
VITE_PORTAL_RECORDS_EDITOR_FUNERAL=false
